{
    "manifest_version": 3,
    "name": "GemiNav AI",
    "version": "1.0.0",
    "description": "AI-powered Web Pilot — voice-first UI navigator and scam protector powered by Gemini.",
    "permissions": [
        "sidePanel",
        "tabCapture",
        "activeTab",
        "scripting",
        "tabs",
        "clipboardRead"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "side_panel": {
        "default_path": "index.html"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "action": {
        "default_title": "Open GemiNav AI"
    },
    "commands": {
        "_execute_side_panel": {
            "suggested_key": {
                "default": "Ctrl+Shift+Q",
                "mac": "Command+Shift+Q"
            },
            "description": "Toggle GemiNav AI Side Panel"
        }
    },
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' http://localhost:8080 ws://localhost:8080 wss://generativelanguage.googleapis.com https://*.run.app wss://*.run.app;"
    }
}