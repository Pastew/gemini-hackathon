# ===== Connection Mode =====
# Choose ONE of the following modes:

# Mode 1: Direct API Key (for Google AI Studio)
# Create your own API KEY at https://aistudio.google.com/apikey
REACT_APP_GEMINI_API_KEY=YOUR_GOOGLE_AI_STUDIO_KEY
REACT_APP_GEMINI_MODEL_ID=gemini-2.5-flash-native-audio-preview-12-2025

# Mode 2: Proxy Mode (for Vertex AI - recommended)
REACT_APP_PROXY_URL=ws://localhost:8080/api/ws

# ===== Vertex AI Configuration (for backend proxy) =====
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_LOCATION=us-central1
# LOCAL ONLY: Use path to your downloaded service account JSON key.
# See service-account.example.json for the template.
# Leave blank when deploying to Cloud Run.
GOOGLE_KEY_FILE=./service-account.json
GEMINI_MODEL_ID=gemini-live-2.5-flash-native-audio # https://docs.cloud.google.com/vertex-ai/generative-ai/docs/models/gemini/2-5-flash-live-api

# ===== Server Configuration =====
PROXY_PORT=8080
PROXY_HOST=0.0.0.0

# ===== Chrome Extension Security =====
# Set this to your Chrome Extension ID after first "Load Unpacked" install.
# Find it at chrome://extensions (the long alphanumeric ID under your extension).
ALLOWED_EXTENSION_ID=your-chrome-extension-id
